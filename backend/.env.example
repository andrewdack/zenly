# ---- LLM provider (the agent + vision judge are NOT locked to one vendor) ----
# Set to "anthropic" (default) or "openai". Switch vendors with this one line.
LLM_PROVIDER=anthropic

# Anthropic (Claude). Used when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI. Used when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- Server ----
PORT=3000
# The custom URL scheme the iOS app registers. The agent texts a tap-to-start link.
DEEPLINK_SCHEME=zenly
