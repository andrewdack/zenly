# ── OpenRouter (vision focus judge + agent chat, one key) ──────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
FOCUS_MODEL=google/gemma-3-12b-it

# ── Agent chat (also via OpenRouter, same key) ─────────────────────────────
AGENT_MODEL=anthropic/claude-sonnet-4-6
# Snitch message generation — trivial task, fast+cheap model is fine
SNITCH_MODEL=anthropic/claude-haiku-4-5

# ── Messaging ──────────────────────────────────────────────────────────────
# "photon" = cloud (needs PHOTON_* below), "local" = Mac imessage-kit
# Defaults to "photon" if PHOTON_PROJECT_ID is set, else "local".
MESSAGE_PROVIDER=

PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=

# ── App ────────────────────────────────────────────────────────────────────
PORT=3001
DEEPLINK_SCHEME=zenly
MAX_IMAGE_BYTES=5000000
